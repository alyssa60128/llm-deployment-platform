discovery.docker "local" {
  host = "unix:///var/run/docker.sock"
}

discovery.relabel "mock_inference_logs" {
  targets = []

  rule {
    source_labels = [
      "__meta_docker_container_label_com_docker_compose_service",
    ]
    regex = "mock-inference"
    action = "keep"
  }

  rule {
    source_labels = [
      "__meta_docker_container_label_com_docker_compose_service",
    ]
    target_label = "service_name"
  }

  rule {
    source_labels = [
      "__meta_docker_container_name",
    ]
    regex = "/(.*)"
    target_label = "container_name"
  }
}

loki.source.docker "local" {
  host = "unix:///var/run/docker.sock"

  targets = discovery.docker.local.targets

  labels = {
    platform = "docker",
    environment = "local",
  }

  relabel_rules = discovery.relabel.mock_inference_logs.rules

  forward_to = [
    loki.write.local.receiver,
  ]
}

loki.write "local" {
  endpoint {
    url = "http://loki:3100/loki/api/v1/push"
  }
}


otelcol.receiver.otlp "local" {
  grpc {
    endpoint = "0.0.0.0:4317"
  }

  http {
    endpoint = "0.0.0.0:4318"
  }

  output {
    traces = [
      otelcol.processor.batch.local.input,
    ]
  }
}

otelcol.processor.batch "local" {
  output {
    traces = [
      otelcol.exporter.otlp.tempo.input,
    ]
  }
}

otelcol.exporter.otlp "tempo" {
  client {
    endpoint = "tempo:4317"

    tls {
      insecure = true
    }
  }
}